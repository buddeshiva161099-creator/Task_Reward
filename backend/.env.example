# Security controls
ENVIRONMENT=development
ALLOW_PUBLIC_REGISTRATION=false
AUTO_SEED_DEFAULT_USERS=false
ALLOW_IN_MEMORY_DB_FALLBACK=false
MAX_UPLOAD_BYTES=5242880
