MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=employee_task_reward
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
